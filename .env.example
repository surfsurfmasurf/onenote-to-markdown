# -----------------------------------------------
# OneNote to Markdown - Environment Configuration
# -----------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# --- Microsoft Azure App Registration ---
# Register your app at https://portal.azure.com
# Under "App registrations" > "New registration"
CLIENT_ID=your_client_id_here

# Generate under "Certificates & secrets" > "Client secrets"
CLIENT_SECRET=your_client_secret_here

# Use "consumers" for personal Microsoft accounts,
# or your Azure tenant ID for work/school accounts.
TENANT_ID=consumers

# --- Output Settings ---
# Directory where exported Markdown files will be saved
OUTPUT_DIR=./output
